#!/usr/bin/env bash
# Full GitNexus re-index (force) with PDG before each commit; smoke-test graph integrity.
# Full --force rebuild keeps control/data-dependence + taint flows accurate at commit
# boundaries (vs. the lighter incremental gitnexus:pdg used mid-session).
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

npm run gitnexus:full-pdg
npm run gitnexus:graph-smoke
