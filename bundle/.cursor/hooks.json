{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/gitnexus-session-primer.sh"
      },
      {
        "command": ".cursor/hooks/gitnexus-session-health.sh"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": ".cursor/hooks/gitnexus-session-health-user.sh"
      },
      {
        "command": ".cursor/hooks/gitnexus-prompt-router.sh"
      }
    ],
    "preToolUse": [
      {
        "command": ".cursor/hooks/gitnexus-shell-staleness-guard.sh",
        "matcher": "^Shell$"
      },
      {
        "command": ".cursor/hooks/gitnexus-grep-guard.sh",
        "matcher": "^(Grep|Glob|SemanticSearch)$"
      },
      {
        "command": ".cursor/hooks/gitnexus-read-guard.sh",
        "matcher": "^Read$"
      },
      {
        "command": ".cursor/hooks/gitnexus-edit-guard.sh",
        "matcher": "^(Write|StrReplace)$"
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/gitnexus-shell-allowlist.sh",
        "matcher": "gitnexus|gitnexus-agent"
      }
    ],
    "beforeMCPExecution": [
      {
        "command": ".cursor/hooks/gitnexus-mcp-allowlist.sh",
        "matcher": "gitnexus"
      }
    ],
    "afterShellExecution": [
      {
        "command": ".cursor/hooks/gitnexus-after-git-commit.sh",
        "matcher": "git\\s+(commit|merge|rebase|cherry-pick|pull)"
      }
    ]
  }
}
